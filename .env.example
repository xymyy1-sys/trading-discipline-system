AUTH_USERNAME=admin
AUTH_PASSWORD=replace-with-a-long-unique-password
# Production can instead set AUTH_PASSWORD_FILE=/run/secrets/auth_password.
AUTH_PASSWORD_FILE=
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123456
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_SECRET_FILE=
AUTH_TOTP_SECRET=
AUTH_TOTP_SECRET_FILE=
# Set true only after HTTPS is configured.
AUTH_COOKIE_SECURE=false
# Secure production default: expose the frontend only to the host reverse proxy.
FRONTEND_BIND_ADDRESS=127.0.0.1
# Use ./backend/data when adopting an existing non-container deployment.
BACKEND_DATA_PATH=backend-data
# JSON array. Replace/add the final HTTPS origin before enabling production TLS.
CORS_ORIGINS=["https://trade.example.com"]
AUDIT_ENABLED=true
AI_API_KEY=
AI_API_KEY_FILE=
AI_MODEL=deepseek-reasoner
AI_BASE_URL=https://api.deepseek.com
AI_PROVIDER=deepseek
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK=
DINGTALK_WEBHOOK_FILE=
DINGTALK_SECRET=
DINGTALK_SECRET_FILE=

# Optional licensed/official overseas evidence adapters. Each endpoint must
# return audited/official JSON with metric_id, name, value, source, a no-credential
# HTTPS source_url, and a timezone-aware published_at no older than 120 hours.
# The configured endpoint fixes metric_kind; rows cannot override it. Leave blank
# to show the metric as unavailable; the system never infers these facts from
# price or volume. The bearer token is server-side only.
GLOBAL_ETF_FLOW_URL=
GLOBAL_KOREA_FOREIGN_FLOW_URL=
GLOBAL_KOREA_LEVERAGE_URL=
GLOBAL_KOREA_RATE_URL=
GLOBAL_OFFICIAL_ADAPTER_TOKEN=

# Optional licensed/official A-share sector non-leveraged flow adapter. The
# endpoint must use HTTPS and return same-trading-day audited/official JSON.
# Non-leveraged flow requires unit=亿元 and methodology_id. Optional ETF evidence
# requires ETF id, unit=份, baseline shares, methodology id, and consistent change.
# The system leaves this evidence unavailable when the contract is incomplete;
# it never relabels Eastmoney order-flow estimates as non-leveraged capital.
SECTOR_AUDITED_FLOW_URL=
SECTOR_AUDITED_FLOW_TOKEN=
SECTOR_AUDITED_FLOW_TOKEN_FILE=

# Optional Korea Investment & Securities credentials for authorised Korean
# single-stock quotes. Without them the UI may use a clearly labelled delayed
# public quote fallback, never an index-derived synthetic stock price.
KIS_APP_KEY=
KIS_APP_SECRET=
